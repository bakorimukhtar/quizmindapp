# Copy to .env.local for local dev. Add the same keys in Vercel → Project → Settings → Environment Variables.

# Supabase (required) — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (required for quizzes & AI tutor)
GOOGLE_AI_API_KEY=your-gemini-api-key

# Optional — defaults to fast models in code if unset
# GEMINI_MODEL=gemini-2.5-flash
